# Copy this file to .env and fill in real values. .env is git-ignored and
# must NEVER be committed. See docs/deployment/legacy-env.md for full details
# on each variable, rotation, and how this interacts with FTP deployment.

APP_ENV=prod

# Database (read by config.php, en/config.php, kmsaadmin/config.php)
DB_HOST=localhost
DB_NAME=change_me
DB_USER=change_me
DB_PASSWORD=change_me

# Google reCAPTCHA (read by kontaktai.php, en/kontaktai.php, form_action.php, en/form_action.php)
RECAPTCHA_SITE_KEY=change_me
RECAPTCHA_SECRET_KEY=change_me

# MapTiler (read by ehl.php, makingbuild.php, makingbuild-en.php, ehl-pastatai.php, en/ehl-pastatai.php)
MAPTILER_KEY=change_me

# Contact form (read by form_action.php, en/form_action.php)
CONTACT_MAIL_TO=change_me@example.com
CONTACT_MAIL_FROM=no-reply@example.com
